tore)","            .environmentObject(blindsup)","        }","        .onChange(of: scenePhase) { phase in","            if phase == .active {","                blindsup.blindsup = false","            }","            if phase == .inactive {","                blindsup.blindsup = true","            }","        }","    }","}","class BlindsStore: ObservableObject {","    @Published var blindsup: Bool","","    init(blindsup: Bool = false) {","        self.blindsup = blindsup","    }","}","","struct BlindsUp {","    var blindsup: Bool","}"]},"tut4_image004.jpg":{"type":"image","identifier":"tut4_image004.jpg","alt":"<#accessible description#>","variants":[{"url":"\/images\/tut4_image004.jpg","traits":["1x","light"]}]},"doc://MyTutorial/tutorials/MyTutorial/Tutorial1#Get-the-student-materials":{"abstract":[{"text":"You’re invited to learn about secure app development in SwiftUI using Xcode. These tutorials will cover:","type":"text"}],"kind":"section","url":"\/tutorials\/mytutorial\/tutorial1#Get-the-student-materials","identifier":"doc:\/\/MyTutorial\/tutorials\/MyTutorial\/Tutorial1#Get-the-student-materials","type":"section","role":"pseudoSymbol","title":"Get the student materials"},"privacy_01.swift":{"identifier":"privacy_01.swift","syntax":"swift","fileType":"swift","type":"file","fileName":"AwakeApp.swift","highlights":[],"content":["import SwiftUI","","@main","struct AwakeApp: App {","    @StateObject private var store = CoffeeStore()","    var body: some Scene {","        WindowGroup {","            ContentView(store: store)","        }","    }","}"]}}}